{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["public/index.html"]
      }
    },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "server.js" },
    { "src": "/danh-muc/(.*)", "dest": "/index.html" },
    { "src": "/san-pham/(.*)", "dest": "/index.html" },
    { "src": "/(.*)", "dest": "public/$1" }
  ],
  "crons": [
    {
      "path": "/api/pos/sync",
      "schedule": "0 0 * * *"
    }
  ]
}
